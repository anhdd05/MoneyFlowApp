<Window x:Class="MoneyFlowApp.AllocateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyFlowApp"
        mc:Ignorable="d"
        Title="AllocateWindow" Height="325" Width="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="TxtBudgetName" FontSize="15" FontWeight="Bold" Margin="0,0,0,4"/>        
        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" x:Name="TxtSummary" Foreground="Gray" Margin="0,0,0,16"/>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Số tiền (₫):" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtAmount" Height="28" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblTxCategory" Text="Danh mục GD:" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="CboTxCategory" DisplayMemberPath="Name" Height="28" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="4" Grid.Column="0" x:Name="LblDate" Text="Ngày:" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <DatePicker Grid.Row="4" Grid.Column="1" x:Name="DpDate" Height="28" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ghi chú:" VerticalAlignment="Center" Margin="0,0,0,10"/>
        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TxtNote" Height="28" Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" x:Name="TxtAvailable" Foreground="Gray" Margin="0,0,0,10" Visibility="Collapsed"/>       
        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" x:Name="TxtError" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Lưu" Width="80" Height="30" Click="BtnSave_Click" Margin="0,0,8,0"/>
            <Button Content="Hủy" Width="80" Height="30" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
