<Window x:Class="MoneyFlowApp.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyFlowApp"
        mc:Ignorable="d"
        Title="ReportWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="12,8">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Hiển thị:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="Rd3Month"  Content="3 tháng"  Margin="0,0,8,0" VerticalAlignment="Center" Checked="RdMonth_Checked"/>
                <RadioButton x:Name="Rd6Month"  Content="6 tháng"  Margin="0,0,8,0" VerticalAlignment="Center" Checked="RdMonth_Checked"/>
                <RadioButton x:Name="Rd12Month" Content="12 tháng" Margin="0,0,24,0" VerticalAlignment="Center" IsChecked="True" Checked="RdMonth_Checked"/>

                <TextBlock Text="Danh mục:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="RdIncome"  Content="Thu nhập" Margin="0,0,8,0" VerticalAlignment="Center" Checked="RdType_Checked"/>
                <RadioButton x:Name="RdExpense" Content="Chi tiêu" VerticalAlignment="Center" IsChecked="True" Checked="RdType_Checked"/>

            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">

                <!-- BIỂU ĐỒ 1: TRÒN -->
                <TextBlock Text="Tỉ lệ danh mục" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,0,0,24">
                    <Canvas x:Name="PieChart" Height="260" Background="White"/>
                </Border>

                <!-- BIỂU ĐỒ 2: CỘT -->
                <TextBlock Text="Thu vs Chi theo tháng" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,0,0,24">
                    <Canvas x:Name="BarChart" Height="220" Background="White"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
