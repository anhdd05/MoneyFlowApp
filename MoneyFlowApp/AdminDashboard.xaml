<Window x:Class="MoneyFlowApp.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - Quản lý hệ thống" Height="450" Width="800" WindowStartupLocation="CenterScreen" Background="#F4F7F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="BẢNG ĐIỀU KHIỂN QUẢN TRỊ VIÊN" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="10" Padding="20" Width="200" Margin="0,0,20,0" BorderBrush="#DCDDE1" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tổng người dùng" Foreground="#7F8C8D" FontSize="14"/>
                    <TextBlock x:Name="TxtTotalUsers" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2980B9"/>
                </StackPanel>
            </Border>
            <Button Content="Tải lại dữ liệu" Click="BtnRefresh_Click" Padding="15,5" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="UserGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderBrush="#DCDDE1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                <DataGridTextColumn Header="Quyền" Binding="{Binding Role}" Width="100"/>
                <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>