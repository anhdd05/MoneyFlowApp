<Window x:Class="MoneyFlowApp.DashBoard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoneyFlowApp.DashBoard"
        mc:Ignorable="d"
        Title="DashBoard" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Menu -->
        <StackPanel Grid.Column="0" Background="#2c3e50">
            <TextBlock Text="MONEY FLOW" Foreground="White" FontSize="20" FontWeight="Bold" Margin="20"/>
            <Button Content="Trang Chủ" Margin="10,5" Padding="5" Background="#34495e" Foreground="White" BorderThickness="0"/>
            <Button Content="Hồ Sơ (Profile)" Margin="10,5" Padding="5" Click="BtnProfile_Click"/>
            <Button Content="Đăng Xuất" Margin="10,50,10,5" Padding="5" Foreground="Red" Click="BtnLogout_Click"/>
        </StackPanel>

        <!-- Main Dashboard Content -->
        <StackPanel Grid.Column="1" Margin="20">
            <TextBlock Text="TỔNG QUAN TÀI CHÍNH THÁNG NÀY" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <UniformGrid Columns="3" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Tổng Thu" Foreground="Green"/>
                    <TextBlock x:Name="TxtTotalIncome" Text="0 đ" FontSize="20" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Tổng Chi" Foreground="Red"/>
                    <TextBlock x:Name="TxtTotalExpense" Text="0 đ" FontSize="20" FontWeight="Bold" Foreground="Red"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Số Dư Tính Toán" Foreground="Blue"/>
                    <TextBlock x:Name="TxtBalance" Text="0 đ" FontSize="20" FontWeight="Bold" Foreground="Blue"/>
                </StackPanel>
            </UniformGrid>

            <TextBlock Text="WIDGET CẢNH BÁO NGÂN SÁCH" FontSize="16" FontWeight="Bold" Margin="0,20,0,10"/>
            <!-- Hiển thị danh sách cảnh báo -->
            <ListBox x:Name="LstAlerts" Background="#fff3e0" BorderThickness="0" Padding="10" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
