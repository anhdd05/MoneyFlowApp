<Window x:Class="MoneyFlowApp.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu" Height="350" Width="350" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Mật khẩu cũ:"/>
            <PasswordBox x:Name="txtOldPass" Height="30" Margin="0,5,0,10"/>
            <TextBlock Text="Mật khẩu mới:"/>
            <PasswordBox x:Name="txtNewPass" Height="30" Margin="0,5,0,10"/>
            <TextBlock Text="Xác nhận mật khẩu mới:"/>
            <PasswordBox x:Name="txtConfirmPass" Height="30" Margin="0,5,0,20"/>
            <Button Content="XÁC NHẬN ĐỔI" Click="btnUpdate_Click" Height="35" Background="OrangeRed" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="txtMsg" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>