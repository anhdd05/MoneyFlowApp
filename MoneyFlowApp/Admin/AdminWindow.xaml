<Window x:Class="MoneyFlowApp.Admin.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MoneyFlowApp.Admin"
        Title="Quản trị Hệ thống - MoneyFlow" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0" Padding="16,12">
            <Grid>
                <TextBlock Text="Khu vực Quản trị (Admin Workspace)" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Button Content="ĐĂNG XUẤT" HorizontalAlignment="Right" Width="100" Height="30" Background="#E74C3C" Foreground="White" FontWeight="Bold" Click="BtnLogout_Click" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="8" x:Name="AdminTabControl" SelectionChanged="AdminTabControl_SelectionChanged">
            <TabItem Header="Tổng quan">
                <local:AdminDashboardControl x:Name="AdminDashboard"/>
            </TabItem>
            <TabItem Header="Danh mục Hệ thống">
                <local:AdminCategoryControl x:Name="AdminCategory"/>
            </TabItem>
            <TabItem Header="Quản lý Người dùng">
                <local:AdminUserControl x:Name="AdminUser"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
